{
  "AWSEBDockerrunVersion": "1",
  "Image": {
    "Name": "openjdk:17-jre-slim",
    "Update": "true"
  },
  "Ports": [
    {
      "ContainerPort": "5000"
    }
  ],
  "Volumes": [
    {
      "HostDirectory": "/var/app/current",
      "ContainerDirectory": "/app"
    }
  ],
  "Logging": "/var/log/eb-docker/containers/eb-current-app"
}
